# AI Model API Keys
# Replace these with your actual keys to enable AI features in the Resolve tab

# Groq API Key (required for Resolve tab AI text generation & summarization)
# Get your key at: https://console.groq.com/keys
VITE_GROQ_API_KEY=your_groq_api_key_here

# Gemini API Key (if used elsewhere in the application)
# Get your key at: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

